{
  "Author": "Chaiwut Chaianuchittrakul",
  "Name": "Deck Status",
  "Description": "Live status tiles for Cursor, Commander sprints, and Claude Code sessions — plus Antigravity git age and GitHub API usage.",
  "Icon": "resources/icon.png",
  "Version": "1.1.0",
  "Category": "Deck Status",
  "CategoryIcon": "resources/icon.png",
  "CodePath": "plugin/app.js",
  "Type": "JavaScript",
  "UUID": "com.ulanzi.ulanzistudio.deckstatus",
  "Actions": [
    {
      "Name": "Cursor",
      "Tooltip": "Cycle Cursor workspaces: elapsed time + status. Tap to cycle sessions.",
      "Icon": "resources/cursorcycle.png",
      "PropertyInspectorPath": "property-inspector/cursor.html",
      "UUID": "com.ulanzi.ulanzistudio.deckstatus.cursorcycle",
      "States": [
        { "Name": "Default", "Image": "resources/cursorcycle.png" }
      ],
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    },
    {
      "Name": "Commander Sprint",
      "Tooltip": "Running sprint progress (done/total). Tap cycles active sprints. Random icon per project.",
      "Icon": "resources/sprint.png",
      "PropertyInspectorPath": "property-inspector/commander.html",
      "UUID": "com.ulanzi.ulanzistudio.deckstatus.sprint",
      "States": [
        { "Name": "Default", "Image": "resources/sprint.png" }
      ],
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    },
    {
      "Name": "Claude (cycle)",
      "Tooltip": "Cycle Claude Code sessions (idle skipped). Elapsed time + status. Tap to cycle.",
      "Icon": "resources/claudecycle.png",
      "PropertyInspectorPath": "property-inspector/claudecycle.html",
      "UUID": "com.ulanzi.ulanzistudio.deckstatus.claudecycle",
      "States": [
        { "Name": "Default", "Image": "resources/claudecycle.png" }
      ],
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    },
    {
      "Name": "Antigravity",
      "Tooltip": "Bind a key to a project path; show its latest commit hash + time since.",
      "Icon": "resources/antigravity.png",
      "PropertyInspectorPath": "property-inspector/antigravity.html",
      "UUID": "com.ulanzi.ulanzistudio.deckstatus.antigravity",
      "States": [
        { "Name": "Default", "Image": "resources/antigravity.png" }
      ],
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    },
    {
      "Name": "GitHub API Usage",
      "Tooltip": "GitHub REST API rate-limit usage % for the hourly window. Tap to refresh.",
      "Icon": "resources/ghrate.png",
      "PropertyInspectorPath": "property-inspector/ghrate.html",
      "UUID": "com.ulanzi.ulanzistudio.deckstatus.ghrate",
      "States": [
        { "Name": "Default", "Image": "resources/ghrate.png" }
      ],
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    }
  ],
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Software": {
    "MinVersion": "3.0.11"
  }
}
